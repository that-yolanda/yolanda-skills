# yolanda-skills 环境变量清单
#
# 实际配置文件：$YO_CONFIG_HOME/config.env（不入仓库）
#   YO_CONFIG_HOME 默认值：macOS/Linux ~/.config/yolanda-skills；Windows %APPDATA%\yolanda-skills
#
# 首次使用时，告诉 agent「帮我配置 yolanda-skills」，它会经 first-time-setup
# 引导你填好值并使其生效：
#   - macOS/Linux：写入 config.env，并在 shell rc 加 source 行
#   - Windows：用 setx 把每个变量设为用户环境变量
#
# 手动初始化：
#   macOS/Linux：cp .env.example ~/.config/yolanda-skills/config.env && 编辑
#   Windows：    用 setx 设置下列变量，或复制本文件到 %APPDATA%\yolanda-skills\config.env 留档

# ===== 目录（个人数据）=====
# 知识库 vault 根（知识库 skill: yo-opentalk / yo-whoami / yo-wiki-atom / yo-wiki-review / yo-utils-music 偏好）
WIKI_DIR=

# 笔记 / 复盘目录根（yo-self-review）
NOTES_DIR=

# ===== Chrome profile（opencli 复用登录 cookie）=====
# 隔离 profile 目录，如 $YO_CONFIG_HOME/chrome-profile
CHROME_PROFILE_DIR=
