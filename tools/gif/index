#!/usr/bin/env bash
# DESC=视频转 GIF 动图

set -e

# 颜色定义
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
NC=$'\033[0m'

log_info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$1"; }
log_ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$1"; }
log_warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$1"; }
log_error() { printf "${RED}[ERROR]${NC} %s\n" "$1"; }

# ==================== 工具函数 ====================

resolve_path() {
    local path="$1"
    if [ -z "$path" ]; then
        echo ""
        return
    fi
    case "$path" in
        /*) echo "$path" ;;
        *)  echo "$(pwd)/$path" ;;
    esac
}

dir_of() {
    echo "$(cd "$(dirname "$1")" && pwd)"
}

check_deps() {
    local missing=0
    if ! command -v ffmpeg >/dev/null 2>&1; then
        log_error "缺少依赖: ffmpeg 未安装"
        missing=1
    fi
    if ! command -v ffprobe >/dev/null 2>&1; then
        log_error "缺少依赖: ffprobe 未安装（通常随 ffmpeg 一起）"
        missing=1
    fi
    if [ "$missing" -eq 1 ]; then
        case "$(uname -s)" in
            Darwin*) log_info "安装: brew install ffmpeg" ;;
            Linux*)  log_info "安装: sudo apt install ffmpeg" ;;
            MINGW*|MSYS*|CYGWIN*) log_info "安装: winget install Gyan.FFmpeg" ;;
        esac
        exit 1
    fi
}

cleanup() {
    if [ -n "$PALETTE_FILE" ] && [ -f "$PALETTE_FILE" ]; then
        rm -f "$PALETTE_FILE"
    fi
    if [ -n "$TEMP_FLAT" ] && [ -f "$TEMP_FLAT" ]; then
        rm -f "$TEMP_FLAT"
    fi
}
trap cleanup EXIT

WORK_DIR="$(pwd)"

# ==================== 帮助信息 ====================

usage() {
    cat <<EOF
gif — 视频转 GIF 动图
技术栈: ffmpeg (两遍调色板生成法)

用法:
  yo gif <file>
  yo gif -i <file> | --input <file>
  yo gif -i <file> [-q h|m|l] | --quality h|m|l
  yo gif -i <file> [-o <output>] | --output <output>

参数:
  -i, --input <file>     输入视频文件路径（必填）
  -o, --output <file>    输出 GIF 路径（可选，默认与输入同目录同名）
  -q, --quality <level>  清晰度: h / m / l（默认: h）
                           h — 原始分辨率，24fps
                           m — 最短边 720px，15fps
                           l — 最短边 480px，12fps
  -h, --help             显示帮助

示例:
  yo gif video.mp4
  yo gif video.mp4 -q m
  yo gif -i video.mp4 -q l -o ./out/result.gif

配置:
  无需额外配置，依赖系统安装的 ffmpeg
EOF
    exit 0
}

# ==================== 参数解析 ====================

INPUT_FILE=""
OUTPUT_FILE=""
QUALITY="h"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            ;;
        -i|--input)
            if [[ -z "${2:-}" ]]; then
                log_error "-i/--input 需要指定文件路径"
                exit 1
            fi
            INPUT_FILE="$2"
            shift 2
            ;;
        -o|--output)
            if [[ -z "${2:-}" ]]; then
                log_error "-o/--output 需要指定输出路径"
                exit 1
            fi
            OUTPUT_FILE="$2"
            shift 2
            ;;
        -q|--quality)
            if [[ -z "${2:-}" ]]; then
                log_error "-q/--quality 需要指定清晰度 (h|m|l)"
                exit 1
            fi
            QUALITY="$2"
            case "$QUALITY" in
                h|m|l) ;;
                *)
                    log_error "不支持的清晰度: $QUALITY（可选: h, m, l）"
                    exit 1
                    ;;
            esac
            shift 2
            ;;
        -i*|--input=*)
            if [[ "$1" == --input=* ]]; then
                INPUT_FILE="${1#--input=}"
            else
                INPUT_FILE="${1#-i}"
            fi
            shift
            ;;
        -o*|--output=*)
            if [[ "$1" == --output=* ]]; then
                OUTPUT_FILE="${1#--output=}"
            else
                OUTPUT_FILE="${1#-o}"
            fi
            shift
            ;;
        -q*|--quality=*)
            if [[ "$1" == --quality=* ]]; then
                QUALITY="${1#--quality=}"
            else
                QUALITY="${1#-q}"
            fi
            case "$QUALITY" in
                h|m|l) ;;
                *)
                    log_error "不支持的清晰度: $QUALITY（可选: h, m, l）"
                    exit 1
                    ;;
            esac
            shift
            ;;
        -*)
            log_error "未知选项: $1"
            usage
            ;;
        *)
            if [[ -z "$INPUT_FILE" ]]; then
                INPUT_FILE="$1"
            else
                log_error "多余参数: $1"
                usage
            fi
            shift
            ;;
    esac
done

if [ -z "$INPUT_FILE" ]; then
    log_error "缺少必填参数: -i <file>"
    usage
fi

# ==================== 路径解析 ====================

INPUT_FILE="$(resolve_path "$INPUT_FILE")"

if [ ! -f "$INPUT_FILE" ]; then
    log_error "视频文件不存在: $INPUT_FILE"
    exit 1
fi

INPUT_DIR="$(dir_of "$INPUT_FILE")"
INPUT_BASENAME="$(basename "$INPUT_FILE")"
FILESTEM="${INPUT_BASENAME%.*}"

if [ -n "$OUTPUT_FILE" ]; then
    FINAL_OUTPUT="$(resolve_path "$OUTPUT_FILE")"
    FINAL_OUTPUT_DIR="$(dir_of "$FINAL_OUTPUT")"
    if [ ! -d "$FINAL_OUTPUT_DIR" ]; then
        mkdir -p "$FINAL_OUTPUT_DIR"
        log_info "已创建输出目录: $FINAL_OUTPUT_DIR"
    fi
else
    FINAL_OUTPUT="${INPUT_DIR}/${FILESTEM}.gif"
fi

PALETTE_FILE="${WORK_DIR}/.gif_palette_${FILESTEM}_$$.png"
TEMP_FLAT=""

# ==================== 依赖检查 ====================

check_deps

# ==================== 清晰度配置 ====================

case "$QUALITY" in
    h) FPS=24; SCALE_FILTER="" ;;
    m) FPS=15; SCALE_FILTER="scale='if(gt(iw,ih),-2,720)':'if(gt(iw,ih),720,-2)':flags=lanczos" ;;
    l) FPS=12; SCALE_FILTER="scale='if(gt(iw,ih),-2,480)':'if(gt(iw,ih),480,-2)':flags=lanczos" ;;
esac

# 构建 filter 前缀: fps + 可选 scale
VF_BASE="fps=${FPS}"
[ -n "$SCALE_FILTER" ] && VF_BASE+=",${SCALE_FILTER}"

# ==================== 半透明检测与处理 ====================

ACTUAL_INPUT="$INPUT_FILE"

PIX_FMT=$(ffprobe -v error -select_streams v:0 -show_entries stream=pix_fmt -of csv=p=0 "$INPUT_FILE" 2>/dev/null || echo "")

case "$PIX_FMT" in
    *a*|rgba|argb|yuva*|gbrap*|pal8)
        log_info "检测到透明通道 (${PIX_FMT})，正在合成白色背景..."
        TEMP_FLAT="${WORK_DIR}/.gif_flat_${FILESTEM}_$$.mp4"
        VID_W=$(ffprobe -v error -select_streams v:0 -show_entries stream=width -of csv=p=0 "$INPUT_FILE")
        VID_H=$(ffprobe -v error -select_streams v:0 -show_entries stream=height -of csv=p=0 "$INPUT_FILE")
        ffmpeg -f lavfi -i "color=white:s=${VID_W}x${VID_H}:d=999,format=rgb24" \
               -i "$INPUT_FILE" \
               -filter_complex "[1:v]format=rgba[vid];[0:v][vid]overlay=0:0:format=auto,format=rgb24" \
               -c:v libx264 -pix_fmt yuv420p -an -y "$TEMP_FLAT" -loglevel error
        ACTUAL_INPUT="$TEMP_FLAT"
        log_ok "透明通道已合成到白色背景"
        ;;
esac

# ==================== 执行 ====================

case "$QUALITY" in
    h) QUALITY_LABEL="高(h)" ;;
    m) QUALITY_LABEL="中(m)" ;;
    l) QUALITY_LABEL="低(l)" ;;
esac

log_info "输入视频:  $INPUT_FILE"
log_info "清晰度:    $QUALITY_LABEL"
log_info "输出文件:  $FINAL_OUTPUT"
echo ""

# ---- Step 1: 生成调色板 ----
log_info "[1/2] 生成调色板..."
ffmpeg -i "$ACTUAL_INPUT" -vf "${VF_BASE},palettegen=stats_mode=full" -y "$PALETTE_FILE" -loglevel error

if [ ! -f "$PALETTE_FILE" ]; then
    log_error "调色板生成失败"
    exit 1
fi
log_ok "调色板生成完成"
echo ""

# ---- Step 2: 生成 GIF ----
log_info "[2/2] 生成 GIF..."
ffmpeg -i "$ACTUAL_INPUT" -i "$PALETTE_FILE" \
       -lavfi "${VF_BASE}[x];[x][1:v]paletteuse=dither=sierra2_4a" \
       -y "$FINAL_OUTPUT" -loglevel error

if [ ! -f "$FINAL_OUTPUT" ]; then
    log_error "GIF 生成失败"
    exit 1
fi

FILESIZE=$(du -h "$FINAL_OUTPUT" | cut -f1)
log_ok "全部完成！文件: $FINAL_OUTPUT ($FILESIZE)"
