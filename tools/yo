#!/usr/bin/env bash
set -euo pipefail

# 解析 symlink，定位真实目录
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BASE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# 加载统一配置（如已存在则导出为环境变量，未配置则不影响）
YO_CONFIG_HOME="${YO_CONFIG_HOME:-$HOME/.config/yolanda-skills}"
[ -f "$YO_CONFIG_HOME/config.env" ] && set -a && . "$YO_CONFIG_HOME/config.env" && set +a

# ==================== 颜色 ====================
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# ==================== 帮助 ====================

show_help() {
    cat <<EOF
${BOLD}yo — 自定义脚本集${NC}

用法:
  yo <subcommand> [options] [arguments]
  yo <command>

命令:
  help, -h, --help      显示帮助
  list, -l, --list      列出所有可用子命令

子命令:
EOF
    # 动态扫描子目录
    for dir in "$BASE_DIR"/*/; do
        [ ! -d "$dir" ] && continue
        name="$(basename "$dir")"
        # 跳过非工具目录
        [ ! -f "$dir/index" ] && continue
        # 从 index 的帮助第一行提取描述
        desc=""
        if [ -f "$dir/index" ]; then
            desc="$(grep -m1 'DESC=' "$dir/index" 2>/dev/null | sed 's/^# *DESC=//' || true)"
            if [ -z "$desc" ]; then
                desc="$(head -5 "$dir/index" | grep -m1 '—' | sed 's/.*— //' || true)"
            fi
        fi
        printf "  %-18s %s\n" "$name" "$desc"
    done
    cat <<EOF

配置:
  将本目录（tools/）加入 PATH 即可全局调用 yo
  环境变量见 $YO_CONFIG_HOME/config.env，详见 README.md
EOF
}

show_list() {
    printf "${BOLD}可用子命令:${NC}\n\n"
    for dir in "$BASE_DIR"/*/; do
        [ ! -d "$dir" ] && continue
        name="$(basename "$dir")"
        [ ! -f "$dir/index" ] && continue
        desc=""
        if [ -f "$dir/index" ]; then
            desc="$(grep -m1 'DESC=' "$dir/index" 2>/dev/null | sed 's/^# *DESC=//' || true)"
            if [ -z "$desc" ]; then
                desc="$(head -5 "$dir/index" | grep -m1 '—' | sed 's/.*— //' || true)"
            fi
        fi
        printf "  ${GREEN}%-14s${NC} %s\n" "$name" "$desc"
    done
}

# ==================== 调度 ====================

SUBCMD="${1:-}"

case "$SUBCMD" in
    ""|help|-h|--help)
        show_help
        ;;
    list|-l|--list)
        show_list
        ;;
    *)
        # 查找子命令
        TARGET="$BASE_DIR/$SUBCMD/index"
        if [ ! -f "$TARGET" ]; then
            printf "${RED}错误: 未知子命令 '$SUBCMD'${NC}\n\n"
            show_list
            exit 1
        fi
        if [ ! -x "$TARGET" ]; then
            printf "${RED}错误: '$SUBCMD/index' 不可执行${NC}\n"
            exit 1
        fi
        shift
        exec "$TARGET" "$@"
        ;;
esac
